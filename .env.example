# Boardwire LLM config
BOARDWIRE_LLM_PROVIDER=none
BOARDWIRE_LLM_MODEL=gpt-5-mini
BOARDWIRE_GEMINI_MODEL=gemini-2.5-flash
BOARDWIRE_MAX_LLM_ITEMS=3
BOARDWIRE_MAX_POSTS_PER_DAY=3
OPENAI_API_KEY=
