# Slack notifications — one Slack App per persona (create at api.slack.com)
# Each app gets the persona name and a custom avatar image.
# Fallback: set SLACK_WEBHOOK_URL to use a single webhook for all three.
SLACK_WEBHOOK_URL_CLAIRE=
SLACK_WEBHOOK_URL_CHLOE=
SLACK_WEBHOOK_URL_MADISON=
SLACK_WEBHOOK_URL=

# Boardwire LLM config
BOARDWIRE_LLM_PROVIDER=none
BOARDWIRE_LLM_MODEL=gpt-5-mini
BOARDWIRE_GEMINI_MODEL=gemini-2.5-flash
BOARDWIRE_MAX_LLM_ITEMS=3
BOARDWIRE_MAX_POSTS_PER_DAY=3
OPENAI_API_KEY=

# Breaking-news burst — let genuinely important stories exceed the routine
# daily cap. An item is "breaking" when its score clears the threshold AND
# (unless corroboration is disabled) it is corroborated: reported by >1 source
# in its cluster, or carrying high community engagement. Breaking items draw
# from a separate daily budget (on top of MAX_POSTS_PER_DAY), bypass the
# near-duplicate gate (a follow-up to an ongoing story is news, not a repost),
# and may trigger an extra publish within a single run.
BOARDWIRE_BREAKING_ENABLED=true
BOARDWIRE_BREAKING_SCORE_THRESHOLD=92
BOARDWIRE_BREAKING_MAX_EXTRA_PER_DAY=3
BOARDWIRE_BREAKING_MAX_EXTRA_PER_RUN=2
BOARDWIRE_BREAKING_REQUIRE_CORROBORATION=true
BOARDWIRE_BREAKING_MIN_ENGAGEMENT=100
GEMINI_API_KEY=
GEMINI_API_KEY_2=

# Newsroom: deep multi-source research (opt-in; runs alongside the normal pipeline)
BOARDWIRE_ENABLE_NEWSROOM=false
BOARDWIRE_NEWSROOM_MAX_STORIES=2
BOARDWIRE_NEWSROOM_FETCH_FULLTEXT=true
BOARDWIRE_NEWSROOM_MAX_FETCH=5
BOARDWIRE_NEWSROOM_FETCH_CHARS=8000
BOARDWIRE_NEWSROOM_WEB_SEARCH=false
BOARDWIRE_NEWSROOM_WEB_RESULTS=4
# Web search backend for the reporter: none | gemini (Google-Search grounding)
BOARDWIRE_WEB_SEARCH_PROVIDER=none

# Web-article export (Tiffany features writer). Articles are written from the
# research dossier (data/dossiers/) when one matches the item's source link.
# Point BOARDWIRE_TIFFANY_MODEL at a stronger model for higher-quality flagship
# articles; BOARDWIRE_TIFFANY_CALL_BUDGET caps how many are written via LLM per
# run (the rest use the dossier-aware fallback).
BOARDWIRE_TIFFANY_MODEL=gemini-2.5-flash
BOARDWIRE_TIFFANY_CALL_BUDGET=3

# Constructive-journalism editorial line (Good-News pivot). Master switch for
# folding the constructive signal into ranking: progress/solutions/recovery
# surface, doom/outrage/clickbait sink (config/editorial.json holds the tunable
# term lists). Unset = use constructive_mode from config (default off). Turn ON
# once Good-News sources are in place.
BOARDWIRE_CONSTRUCTIVE_MODE=false

# Publisher config (safe defaults)
BOARDWIRE_PUBLISHER=dry_run
BOARDWIRE_REAL_PUBLISH_ENABLED=false
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=
X_CONSUMER_KEY=
X_CONSUMER_KEY_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# Mastodon publisher (free, no app review). Create an access token at
# <your-instance>/settings/applications with the "write:statuses" and
# "write:media" scopes. MASTODON_API_BASE_URL is your instance root URL.
MASTODON_API_BASE_URL=
MASTODON_ACCESS_TOKEN=

# Instagram publisher (free API; Business/Creator account linked to a Facebook
# Page + app review required). The Graph API fetches the card by URL, so cards
# must be publicly hosted: INSTAGRAM_IMAGE_BASE_URL is the public base under
# which generated/cards/<id>.png is served (e.g. https://boardwire.example/cards).
# INSTAGRAM_GRAPH_API_VERSION is optional (defaults to a recent version).
INSTAGRAM_USER_ID=
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_IMAGE_BASE_URL=
INSTAGRAM_GRAPH_API_VERSION=

# Threads publisher (free API; Meta app + Tech Provider Verification required).
# Text-only posts work without an image. THREADS_IMAGE_BASE_URL is optional —
# set it (like the Instagram one) to attach the public card image to the post.
# THREADS_GRAPH_API_VERSION is optional (defaults to a recent version).
THREADS_USER_ID=
THREADS_ACCESS_TOKEN=
THREADS_IMAGE_BASE_URL=
THREADS_GRAPH_API_VERSION=

# Experimental local-only browser publishing fallback for X
BOARDWIRE_ALLOW_BROWSER_PUBLISH=false
BOARDWIRE_BROWSER_AUTO_CLICK_POST=false

# Unofficial X publisher (twikit). No paid X API key required.
# Initial setup: run `python -m src.main --x-login` — opens a browser,
# you log in to X normally, cookies are extracted to X_COOKIES_PATH.
# For CI: base64-encode the cookies file and store as X_COOKIES_B64 secret.
X_COOKIES_PATH=.x-cookies.json
X_COOKIES_B64=

# Virality model — learn from comparable larger channels (opt-in).
# With few of our own posts the model can't learn what works, so it can also
# study the public posts of larger channels in our niche, fetched via the public
# (no-auth) Bluesky AppView. Each account's engagement is normalised into a
# per-account z-score so big accounts don't just teach "get more followers".
# Leave BOARDWIRE_VIRALITY_REFERENCE_HANDLES empty to keep training on our posts
# only (unchanged behaviour).
#   - REFERENCE_HANDLES: comma-separated Bluesky handles, e.g.
#       handle1.bsky.social,handle2.bsky.social
#   - REFERENCE_MAX_POSTS: max posts pulled per handle (default 100)
#   - REFERENCE_MIN_POSTS: min mature posts an account needs before its posts are
#       used (a z-score needs a few samples; default 5)
#   - OWN_WEIGHT: training weight for our own posts vs. reference posts, to keep
#       the model anchored on our voice (default 3.0)
BOARDWIRE_VIRALITY_REFERENCE_HANDLES=
BOARDWIRE_VIRALITY_REFERENCE_MAX_POSTS=100
BOARDWIRE_VIRALITY_REFERENCE_MIN_POSTS=5
BOARDWIRE_VIRALITY_OWN_WEIGHT=3.0
